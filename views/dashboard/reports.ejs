<%- include('../partials/head', { title: 'Berichte' }) %>

<div class="flex h-full min-h-screen">
  <%- include('../partials/sidebar') %>

  <main class="flex-1 lg:ml-64 pt-14 lg:pt-0 p-4 lg:p-8 min-w-0">
    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-2xl font-bold text-slate-900 dark:text-white">DMARC Berichte</h1>
        <p class="text-slate-500 dark:text-slate-400 text-sm mt-1"><%= total.toLocaleString('de-DE') %> Einträge gefunden</p>
      </div>
      <% if (isAdmin) { %>
      <a href="/api/export?days=<%= filters.days %>&dkim=<%= filters.dkim %>&spf=<%= filters.spf %>&disposition=<%= filters.disposition %>&search=<%= filters.search %>&category=<%= filters.category %>"
         class="flex items-center gap-2 px-4 py-2 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 text-slate-700 dark:text-slate-200 rounded-lg text-sm font-medium hover:bg-slate-50 dark:hover:bg-slate-700 shadow-sm transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
        CSV Export
      </a>
      <% } %>
    </div>

    <!-- Category Tabs -->
    <div class="flex gap-2 mb-4 flex-wrap">
      <a href="/dashboard/reports?days=<%= filters.days %>&dkim=<%= filters.dkim %>&spf=<%= filters.spf %>&disposition=<%= filters.disposition %>&search=<%= filters.search %>"
         class="flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium border transition-colors
                <%= !filters.category ? 'bg-slate-800 dark:bg-slate-200 text-white dark:text-slate-900 border-slate-800 dark:border-slate-200' : 'bg-white dark:bg-slate-800 text-slate-600 dark:text-slate-300 border-slate-200 dark:border-slate-700 hover:bg-slate-50 dark:hover:bg-slate-700' %>">
        Alle <span class="text-xs px-1.5 py-0.5 rounded-full <%= !filters.category ? 'bg-slate-600 dark:bg-slate-400 text-white dark:text-slate-900' : 'bg-slate-100 dark:bg-slate-700 text-slate-500 dark:text-slate-400' %>"><%= total %></span>
      </a>
      <a href="/dashboard/reports?category=compatible&days=<%= filters.days %>&search=<%= filters.search %>"
         class="flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium border transition-colors
                <%= filters.category==='compatible' ? 'bg-green-600 text-white border-green-600' : 'bg-white dark:bg-slate-800 text-slate-600 dark:text-slate-300 border-slate-200 dark:border-slate-700 hover:bg-slate-50 dark:hover:bg-slate-700' %>">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
        Compatible <span class="text-xs px-1.5 py-0.5 rounded-full <%= filters.category==='compatible' ? 'bg-green-500 text-white' : 'bg-green-100 dark:bg-green-900/40 text-green-700 dark:text-green-400' %>"><%= categories.compatible.toLocaleString('de-DE') %></span>
      </a>
      <a href="/dashboard/reports?category=forwarded&days=<%= filters.days %>&search=<%= filters.search %>"
         class="flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium border transition-colors
                <%= filters.category==='forwarded' ? 'bg-blue-600 text-white border-blue-600' : 'bg-white dark:bg-slate-800 text-slate-600 dark:text-slate-300 border-slate-200 dark:border-slate-700 hover:bg-slate-50 dark:hover:bg-slate-700' %>">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 9l3 3m0 0l-3 3m3-3H8m13 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        Weitergeleitet <span class="text-xs px-1.5 py-0.5 rounded-full <%= filters.category==='forwarded' ? 'bg-blue-500 text-white' : 'bg-blue-100 dark:bg-blue-900/40 text-blue-700 dark:text-blue-400' %>"><%= categories.forwarded.toLocaleString('de-DE') %></span>
      </a>
      <a href="/dashboard/reports?category=failed&days=<%= filters.days %>&search=<%= filters.search %>"
         class="flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium border transition-colors
                <%= filters.category==='failed' ? 'bg-red-600 text-white border-red-600' : 'bg-white dark:bg-slate-800 text-slate-600 dark:text-slate-300 border-slate-200 dark:border-slate-700 hover:bg-slate-50 dark:hover:bg-slate-700' %>">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
        Fehlgeschlagen <span class="text-xs px-1.5 py-0.5 rounded-full <%= filters.category==='failed' ? 'bg-red-500 text-white' : 'bg-red-100 dark:bg-red-900/40 text-red-700 dark:text-red-400' %>"><%= categories.failed.toLocaleString('de-DE') %></span>
      </a>
    </div>

    <!-- Filter Bar -->
    <form method="GET" class="bg-white dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700 shadow-sm p-4 mb-4">
      <input type="hidden" name="category" value="<%= filters.category %>">
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-3">
        <div>
          <label class="block text-xs font-medium text-slate-500 dark:text-slate-400 mb-1">Suche</label>
          <input type="text" name="search" value="<%= filters.search %>" placeholder="IP, Org, Domain..."
                 class="w-full text-sm border border-slate-200 dark:border-slate-600 rounded-lg px-3 py-2 bg-white dark:bg-slate-700 text-slate-800 dark:text-slate-100 placeholder-slate-400 dark:placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-blue-500">
        </div>
        <div>
          <label class="block text-xs font-medium text-slate-500 dark:text-slate-400 mb-1">DKIM</label>
          <select name="dkim" class="w-full text-sm border border-slate-200 dark:border-slate-600 rounded-lg px-3 py-2 bg-white dark:bg-slate-700 text-slate-800 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500">
            <option value="">Alle</option>
            <option value="pass" <%= filters.dkim==='pass' ? 'selected' : '' %>>Pass</option>
            <option value="fail" <%= filters.dkim==='fail' ? 'selected' : '' %>>Fail</option>
          </select>
        </div>
        <div>
          <label class="block text-xs font-medium text-slate-500 dark:text-slate-400 mb-1">SPF</label>
          <select name="spf" class="w-full text-sm border border-slate-200 dark:border-slate-600 rounded-lg px-3 py-2 bg-white dark:bg-slate-700 text-slate-800 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500">
            <option value="">Alle</option>
            <option value="pass" <%= filters.spf==='pass' ? 'selected' : '' %>>Pass</option>
            <option value="fail" <%= filters.spf==='fail' ? 'selected' : '' %>>Fail</option>
          </select>
        </div>
        <div>
          <label class="block text-xs font-medium text-slate-500 dark:text-slate-400 mb-1">Disposition</label>
          <select name="disposition" class="w-full text-sm border border-slate-200 dark:border-slate-600 rounded-lg px-3 py-2 bg-white dark:bg-slate-700 text-slate-800 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500">
            <option value="">Alle</option>
            <option value="none"       <%= filters.disposition==='none'       ? 'selected' : '' %>>None</option>
            <option value="quarantine" <%= filters.disposition==='quarantine' ? 'selected' : '' %>>Quarantine</option>
            <option value="reject"     <%= filters.disposition==='reject'     ? 'selected' : '' %>>Reject</option>
          </select>
        </div>
        <div>
          <label class="block text-xs font-medium text-slate-500 dark:text-slate-400 mb-1">Zeitraum</label>
          <select name="days" class="w-full text-sm border border-slate-200 dark:border-slate-600 rounded-lg px-3 py-2 bg-white dark:bg-slate-700 text-slate-800 dark:text-slate-100 focus:outline-none focus:ring-2 focus:ring-blue-500">
            <option value="7"  <%= filters.days==7  ? 'selected' : '' %>>7 Tage</option>
            <option value="30" <%= filters.days==30 ? 'selected' : '' %>>30 Tage</option>
            <option value="90" <%= filters.days==90 ? 'selected' : '' %>>90 Tage</option>
          </select>
        </div>
        <div class="flex items-end gap-2">
          <button type="submit" class="flex-1 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-lg px-3 py-2 transition-colors">Filtern</button>
          <a href="/dashboard/reports" class="text-sm text-slate-400 dark:text-slate-500 hover:text-slate-600 dark:hover:text-slate-300 px-2 py-2">✕</a>
        </div>
      </div>
    </form>

    <!-- Table -->
    <div class="bg-white dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700 shadow-sm overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-slate-50 dark:bg-slate-700/60 border-b border-slate-200 dark:border-slate-700">
            <tr>
              <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase">Datum</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase">Organisation</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase">Domain</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase">Quell-IP</th>
              <th class="px-4 py-3 text-center text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase">Anzahl</th>
              <th class="px-4 py-3 text-center text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase">DKIM</th>
              <th class="px-4 py-3 text-center text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase">SPF</th>
              <th class="px-4 py-3 text-center text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase">Kategorie</th>
              <th class="px-4 py-3 text-center text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase">Disposition</th>
              <th class="px-4 py-3"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-50 dark:divide-slate-700/50">
            <% if (records.length === 0) { %>
            <tr><td colspan="10" class="px-4 py-12 text-center text-slate-400 dark:text-slate-500">Keine Einträge gefunden</td></tr>
            <% } %>
            <% records.forEach(function(r) {
              const isCompatible = r.evaluated_dkim === 'pass' && r.evaluated_spf === 'pass';
              const isForwarded  = !isCompatible && (r.evaluated_dkim === 'pass' || r.evaluated_spf === 'pass');
            %>
            <tr class="hover:bg-slate-50 dark:hover:bg-slate-700/30 cursor-pointer" onclick="toggleRow('<%= r.id %>')">
              <td class="px-4 py-3 text-slate-600 dark:text-slate-300 whitespace-nowrap"><%= new Date(r.date_range_begin).toLocaleDateString('de-DE') %></td>
              <td class="px-4 py-3 font-medium text-slate-800 dark:text-slate-200 max-w-xs truncate"><%= r.org_name %></td>
              <td class="px-4 py-3 text-slate-600 dark:text-slate-300"><%= r.domain %></td>
              <td class="px-4 py-3 font-mono text-slate-700 dark:text-slate-300 text-xs"><%= isAdmin ? r.source_ip : anonIp(r.source_ip) %></td>
              <td class="px-4 py-3 text-center font-semibold text-slate-700 dark:text-slate-200"><%= r.mail_count %></td>
              <td class="px-4 py-3 text-center">
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium
                  <%= r.evaluated_dkim === 'pass' ? 'bg-green-100 dark:bg-green-900/40 text-green-700 dark:text-green-400' : 'bg-red-100 dark:bg-red-900/40 text-red-700 dark:text-red-400' %>">
                  <%= r.evaluated_dkim %>
                </span>
              </td>
              <td class="px-4 py-3 text-center">
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium
                  <%= r.evaluated_spf === 'pass' ? 'bg-green-100 dark:bg-green-900/40 text-green-700 dark:text-green-400' : 'bg-red-100 dark:bg-red-900/40 text-red-700 dark:text-red-400' %>">
                  <%= r.evaluated_spf %>
                </span>
              </td>
              <td class="px-4 py-3 text-center">
                <% if (isCompatible) { %>
                  <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 dark:bg-green-900/40 text-green-700 dark:text-green-400">✓ Compatible</span>
                <% } else if (isForwarded) { %>
                  <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-blue-100 dark:bg-blue-900/40 text-blue-700 dark:text-blue-400">→ Forwarded</span>
                <% } else { %>
                  <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-red-100 dark:bg-red-900/40 text-red-700 dark:text-red-400">✗ Failed</span>
                <% } %>
              </td>
              <td class="px-4 py-3 text-center">
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium
                  <%= r.evaluated_disposition === 'none' ? 'bg-green-100 dark:bg-green-900/40 text-green-700 dark:text-green-400' :
                      r.evaluated_disposition === 'quarantine' ? 'bg-yellow-100 dark:bg-yellow-900/40 text-yellow-700 dark:text-yellow-400' : 'bg-red-100 dark:bg-red-900/40 text-red-700 dark:text-red-400' %>">
                  <%= r.evaluated_disposition %>
                </span>
              </td>
              <td class="px-4 py-3">
                <a href="/dashboard/reports/<%= r.id %>" onclick="event.stopPropagation()"
                   class="text-xs text-blue-600 dark:text-blue-400 hover:underline whitespace-nowrap">Details →</a>
              </td>
            </tr>
            <tr id="detail-<%= r.id %>" class="hidden bg-slate-50 dark:bg-slate-700/30">
              <td colspan="10" class="px-4 py-4">
                <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 text-xs text-slate-600 dark:text-slate-300">
                  <div>
                    <p class="font-semibold text-slate-700 dark:text-slate-200 mb-1">Auth Results</p>
                    <% if (r.auth_results) { %>
                      <% if (r.auth_results.dkim) { %><p><span class="font-medium">DKIM Domain:</span> <%= r.auth_results.dkim.domain || '-' %></p><p><span class="font-medium">Selector:</span> <%= r.auth_results.dkim.selector || '-' %></p><% } %>
                      <% if (r.auth_results.spf) { %><p class="mt-1"><span class="font-medium">SPF Domain:</span> <%= r.auth_results.spf.domain || '-' %></p><% } %>
                    <% } %>
                  </div>
                  <div>
                    <p class="font-semibold text-slate-700 dark:text-slate-200 mb-1">Identifiers</p>
                    <% if (r.identifiers) { %>
                    <p><span class="font-medium">Header From:</span> <%= r.identifiers.header_from || '-' %></p>
                    <p><span class="font-medium">Envelope From:</span> <%= r.identifiers.envelope_from || '-' %></p>
                    <% } %>
                  </div>
                  <div>
                    <p class="font-semibold text-slate-700 dark:text-slate-200 mb-1">Policy</p>
                    <% if (r.policy_published) { %>
                    <p><span class="font-medium">p:</span> <%= r.policy_published.p || '-' %></p>
                    <p><span class="font-medium">sp:</span> <%= r.policy_published.sp || '-' %></p>
                    <p><span class="font-medium">adkim:</span> <%= r.policy_published.adkim === 'r' ? 'Relaxed' : 'Strict' %></p>
                    <% } %>
                    <a href="/dashboard/reports/<%= r.id %>" class="inline-block mt-2 text-blue-600 dark:text-blue-400 hover:underline">Vollständige Details →</a>
                  </div>
                </div>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <!-- Pagination -->
      <% if (totalPages > 1) { %>
      <div class="px-4 py-3 border-t border-slate-100 dark:border-slate-700 flex items-center justify-between">
        <p class="text-xs text-slate-500 dark:text-slate-400">
          <%= ((page-1)*limit)+1 %>–<%= Math.min(page*limit, total) %> von <%= total.toLocaleString('de-DE') %>
        </p>
        <div class="flex gap-1">
          <% if (page > 1) { %>
          <a href="?page=<%= page-1 %>&limit=<%= limit %>&category=<%= filters.category %>&dkim=<%= filters.dkim %>&spf=<%= filters.spf %>&disposition=<%= filters.disposition %>&days=<%= filters.days %>&search=<%= filters.search %>"
             class="px-3 py-1.5 text-xs border border-slate-200 dark:border-slate-600 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-700 text-slate-600 dark:text-slate-300">← Zurück</a>
          <% } %>
          <% for(let i = Math.max(1,page-2); i <= Math.min(totalPages, page+2); i++) { %>
          <a href="?page=<%= i %>&limit=<%= limit %>&category=<%= filters.category %>&dkim=<%= filters.dkim %>&spf=<%= filters.spf %>&disposition=<%= filters.disposition %>&days=<%= filters.days %>&search=<%= filters.search %>"
             class="px-3 py-1.5 text-xs border rounded-lg <%= i===page ? 'bg-blue-600 text-white border-blue-600' : 'border-slate-200 dark:border-slate-600 hover:bg-slate-50 dark:hover:bg-slate-700 text-slate-600 dark:text-slate-300' %>"><%= i %></a>
          <% } %>
          <% if (page < totalPages) { %>
          <a href="?page=<%= page+1 %>&limit=<%= limit %>&category=<%= filters.category %>&dkim=<%= filters.dkim %>&spf=<%= filters.spf %>&disposition=<%= filters.disposition %>&days=<%= filters.days %>&search=<%= filters.search %>"
             class="px-3 py-1.5 text-xs border border-slate-200 dark:border-slate-600 rounded-lg hover:bg-slate-50 dark:hover:bg-slate-700 text-slate-600 dark:text-slate-300">Weiter →</a>
          <% } %>
        </div>
      </div>
      <% } %>
    </div>
  </main>
</div>

<script>
function toggleRow(id) {
  document.getElementById('detail-' + id)?.classList.toggle('hidden');
}
</script>

</body>
</html>
