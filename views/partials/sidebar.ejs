      </svg>
      Übersicht
    </a>

    <!-- Sektion: Bedrohungen -->
    <div class="pt-4 mt-2">
      <p class="px-3 text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">Bedrohungen</p>
