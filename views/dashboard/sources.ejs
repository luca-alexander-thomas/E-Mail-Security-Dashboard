<%- include('../partials/head', { title: 'Quell-IPs' }) %>

<div class="flex h-full min-h-screen">
  <%- include('../partials/sidebar') %>

  <main class="flex-1 lg:ml-64 pt-14 lg:pt-0 p-4 lg:p-8 min-w-0">
    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-2xl font-bold text-slate-900 dark:text-white">Quell-IP Analyse</h1>
        <p class="text-slate-500 dark:text-slate-400 text-sm mt-1"><%= sources.length %> eindeutige IPs in den letzten <%= days %> Tagen</p>
      </div>
      <div class="flex items-center gap-3">
        <select onchange="window.location.href='?days='+this.value"
                class="text-sm border border-slate-200 dark:border-slate-700 rounded-lg px-3 py-2 bg-white dark:bg-slate-800 text-slate-700 dark:text-slate-200 focus:outline-none focus:ring-2 focus:ring-blue-500">
          <option value="7"  <%= days==7  ? 'selected' : '' %>>Letzte 7 Tage</option>
          <option value="30" <%= days==30 ? 'selected' : '' %>>Letzte 30 Tage</option>
          <option value="90" <%= days==90 ? 'selected' : '' %>>Letzte 90 Tage</option>
        </select>
        <a href="/api/export?days=<%= days %>"
           class="flex items-center gap-2 px-3 py-2 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 text-slate-700 dark:text-slate-200 rounded-lg text-sm font-medium hover:bg-slate-50 dark:hover:bg-slate-700 shadow-sm transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
          CSV Export
        </a>
      </div>
    </div>

    <!-- Summary Cards -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
      <div class="bg-white dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700 p-4 shadow-sm">
        <p class="text-xs font-medium text-slate-500 dark:text-slate-400 uppercase">Einzigartige IPs</p>
        <p class="text-2xl font-bold text-slate-900 dark:text-white mt-1"><%= sources.length %></p>
      </div>
      <div class="bg-white dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700 p-4 shadow-sm">
        <p class="text-xs font-medium text-slate-500 dark:text-slate-400 uppercase">100% Pass</p>
        <p class="text-2xl font-bold text-green-600 dark:text-green-400 mt-1"><%= sources.filter(s => s.passRate === 100).length %></p>
      </div>
      <div class="bg-white dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700 p-4 shadow-sm">
        <p class="text-xs font-medium text-slate-500 dark:text-slate-400 uppercase">Teilweise Pass</p>
        <p class="text-2xl font-bold text-yellow-600 dark:text-yellow-400 mt-1"><%= sources.filter(s => s.passRate > 0 && s.passRate < 100).length %></p>
      </div>
      <div class="bg-white dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700 p-4 shadow-sm">
        <p class="text-xs font-medium text-slate-500 dark:text-slate-400 uppercase">0% Pass (kritisch)</p>
        <p class="text-2xl font-bold text-red-600 dark:text-red-400 mt-1"><%= sources.filter(s => s.passRate === 0).length %></p>
      </div>
    </div>

    <!-- Table -->
    <div class="bg-white dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700 shadow-sm overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-slate-50 dark:bg-slate-700/60 border-b border-slate-200 dark:border-slate-700">
            <tr>
              <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase w-8">#</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase">IP-Adresse</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase">Hostname (rDNS)</th>
              <th class="px-4 py-3 text-right text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase">E-Mails</th>
              <th class="px-4 py-3 text-right text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase">Pass</th>
              <th class="px-4 py-3 text-right text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase">Fail</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase" style="min-width:180px">Pass Rate</th>
              <th class="px-4 py-3 text-center text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase">Disposition</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase">Gemeldet von</th>
              <th class="px-4 py-3"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-50 dark:divide-slate-700/50">
            <% sources.forEach(function(s, i) { %>
            <tr class="hover:bg-slate-50 dark:hover:bg-slate-700/30">
              <td class="px-4 py-3 text-slate-400 dark:text-slate-500 text-xs"><%= i+1 %></td>
              <td class="px-4 py-3 font-mono font-medium text-slate-800 dark:text-slate-200"><%= s.sourceIp %></td>
              <td class="px-4 py-3 text-xs text-slate-500 dark:text-slate-400 font-mono rdns-cell" data-ip="<%= s.sourceIp %>">
                <span class="text-slate-300 dark:text-slate-600">Wird geladen…</span>
              </td>
              <td class="px-4 py-3 text-right text-slate-700 dark:text-slate-200"><%= s.totalEmails.toLocaleString('de-DE') %></td>
              <td class="px-4 py-3 text-right text-green-600 dark:text-green-400 font-medium"><%= s.passed.toLocaleString('de-DE') %></td>
              <td class="px-4 py-3 text-right <%= s.failed > 0 ? 'text-red-600 dark:text-red-400 font-medium' : 'text-slate-400 dark:text-slate-500' %>"><%= s.failed.toLocaleString('de-DE') %></td>
              <td class="px-4 py-3">
                <div class="flex items-center gap-2">
                  <div class="flex-1 h-2 bg-slate-100 dark:bg-slate-700 rounded-full">
                    <div class="h-2 rounded-full <%= s.passRate >= 95 ? 'bg-green-500' : s.passRate >= 80 ? 'bg-yellow-500' : s.passRate >= 50 ? 'bg-orange-500' : 'bg-red-500' %>"
                         style="width:<%= s.passRate %>%"></div>
                  </div>
                  <span class="text-xs font-semibold w-10 text-right
                    <%= s.passRate >= 95 ? 'text-green-700 dark:text-green-400' : s.passRate >= 80 ? 'text-yellow-700 dark:text-yellow-400' : 'text-red-700 dark:text-red-400' %>">
                    <%= s.passRate %>%
                  </span>
                </div>
              </td>
              <td class="px-4 py-3 text-center">
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium
                  <%= s.lastDisposition === 'none' ? 'bg-green-100 dark:bg-green-900/40 text-green-700 dark:text-green-400' :
                      s.lastDisposition === 'quarantine' ? 'bg-yellow-100 dark:bg-yellow-900/40 text-yellow-700 dark:text-yellow-400' : 'bg-red-100 dark:bg-red-900/40 text-red-700 dark:text-red-400' %>">
                  <%= s.lastDisposition %>
                </span>
              </td>
              <td class="px-4 py-3 text-xs text-slate-500 dark:text-slate-400 max-w-xs truncate" title="<%= s.reportingOrgs %>"><%= s.reportingOrgs %></td>
              <td class="px-4 py-3">
                <a href="/dashboard/reports?search=<%= s.sourceIp %>&days=<%= days %>"
                   class="text-xs text-blue-600 dark:text-blue-400 hover:underline whitespace-nowrap">Berichte →</a>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </main>
</div>

<script>
const cells = document.querySelectorAll('.rdns-cell');
cells.forEach((cell, i) => {
  const ip = cell.dataset.ip;
  setTimeout(() => {
    fetch('/api/rdns/' + encodeURIComponent(ip))
      .then(r => r.json())
      .then(d => {
        cell.innerHTML = d.hostname
          ? `<span>${d.hostname}</span>`
          : `<span class="text-slate-300 dark:text-slate-600">—</span>`;
      })
      .catch(() => { cell.innerHTML = '<span class="text-slate-300 dark:text-slate-600">—</span>'; });
  }, i * 80);
});
</script>

</body>
</html>
