# Server
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000
SESSION_SECRET=change-this-to-a-very-long-random-string-min-32-chars

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=dmarc_user
DB_PASSWORD=your_db_password
DB_NAME=dmarc_db
DB_TABLE=dmarc_reports

# Microsoft Entra ID (Azure AD)
# Wird für OIDC-Login UND Graph API Client Credentials verwendet.
# Benötigte App-Permissions (Application, nicht Delegated):
#   SecurityEvents.Read.All, Reports.Read.All, SecurityAlert.Read.All
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=your-client-secret-value
AZURE_REDIRECT_URI=http://localhost:3000/auth/callback

# DNS Health Check
# Kommagetrennte Liste der zu prüfenden Domains
DNS_CHECK_DOMAINS=example.com
# DKIM-Selector (Standard: selector1 für Microsoft 365)
DNS_CHECK_DKIM_SELECTOR=selector1

# Dev-Tools: Daten-Abruf-Buttons in der Sidebar anzeigen
# Auf true setzen um manuelle Refresh-Buttons anzuzeigen (unabhängig von NODE_ENV)
SHOW_DEV_TOOLS=false
