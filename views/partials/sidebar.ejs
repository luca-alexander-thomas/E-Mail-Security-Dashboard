  <!-- User + Theme Toggle -->
  <div class="border-t border-slate-800 px-4 py-4 space-y-3">
    <button onclick="toggleTheme()" id="theme-toggle"
            class="w-full flex items-center justify-between px-3 py-2 rounded-lg text-slate-400 hover:text-white hover:bg-slate-800 transition-colors text-sm">
      <span class="flex items-center gap-2">
        <svg id="icon-moon" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
        </svg>
        <svg id="icon-sun" class="w-4 h-4 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
        </svg>
        <span id="theme-label">Dark Mode</span>
      </span>
      <div id="theme-switch" class="relative w-9 h-5 rounded-full transition-colors bg-slate-700">
        <div id="theme-thumb" class="absolute top-0.5 left-0.5 w-4 h-4 bg-slate-400 rounded-full transition-transform"></div>
      </div>
    </button>

    <div class="flex items-center gap-3">
      <div class="w-8 h-8 bg-blue-500 rounded-full flex items-center justify-center flex-shrink-0">
        <span class="text-white text-xs font-bold">
          <%= (user.given_name || user.name || 'U').charAt(0).toUpperCase() %>
        </span>
      </div>
      <div class="flex-1 min-w-0">
        <p class="text-white text-xs font-medium truncate"><%= user.name || user.email %></p>
        <p class="text-slate-400 text-xs truncate"><%= user.email %></p>
      </div>
    </div>
    <a href="/auth/logout"
       class="flex items-center gap-2 text-slate-400 hover:text-white text-xs transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
      </svg>
      Abmelden
    </a>
  </div>
</aside>

<script>
function toggleTheme() {
  const isDark = document.documentElement.classList.toggle('dark');
  localStorage.theme = isDark ? 'dark' : 'light';
  updateToggleUI(isDark);
}

function updateToggleUI(isDark) {
  const moon  = document.getElementById('icon-moon');
  const sun   = document.getElementById('icon-sun');
  const label = document.getElementById('theme-label');
  const sw    = document.getElementById('theme-switch');
  const thumb = document.getElementById('theme-thumb');

  if (isDark) {
    moon.classList.add('hidden');    sun.classList.remove('hidden');
    label.textContent = 'Light Mode';
    sw.classList.replace('bg-slate-700', 'bg-blue-500');
    thumb.classList.add('translate-x-4');
    thumb.classList.replace('bg-slate-400', 'bg-white');
  } else {
    sun.classList.add('hidden');     moon.classList.remove('hidden');
    label.textContent = 'Dark Mode';
    sw.classList.replace('bg-blue-500', 'bg-slate-700');
    thumb.classList.remove('translate-x-4');
    thumb.classList.replace('bg-white', 'bg-slate-400');
  }
}

updateToggleUI(document.documentElement.classList.contains('dark'));

// Mobile sidebar toggle
(function() {
  const btn     = document.getElementById('mobile-menu-btn');
  const overlay = document.getElementById('sidebar-overlay');
  const sidebar = document.querySelector('aside');
  function open() {
    sidebar?.classList.remove('-translate-x-full');
    overlay?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }
  function close() {
    sidebar?.classList.add('-translate-x-full');
    overlay?.classList.add('hidden');
    document.body.style.overflow = '';
  }
  btn?.addEventListener('click', open);
  overlay?.addEventListener('click', close);
  // Close on link navigation (mobile UX)
  sidebar?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
    if (window.innerWidth < 1024) close();
  }));
})();

async function refreshService(service) {
  const btn = document.querySelector(`.refresh-btn[data-service="${service}"]`);
  const status = document.getElementById('refresh-status');
  if (btn) { btn.disabled = true; btn.textContent = '...'; }
  if (status) { status.textContent = 'Wird abgerufen...'; status.classList.remove('hidden', 'text-green-400', 'text-red-400'); status.classList.add('text-slate-400'); }
  try {
    const r = await fetch(`/api/admin/refresh?service=${service}`, { method: 'POST' });
    const data = await r.json();
    if (status) { status.textContent = data.started ? 'Gestartet – Seite neu laden um Ergebnisse zu sehen.' : 'Fehler'; status.classList.replace('text-slate-400', data.started ? 'text-green-400' : 'text-red-400'); }
  } catch (e) {
    if (status) { status.textContent = 'Netzwerkfehler'; status.classList.replace('text-slate-400', 'text-red-400'); }
  }
  if (btn) {
    const labels = { dns: 'DNS', securescore: 'Sec Score', mailflow: 'Mail Flow', emailactivity: 'Aktivität', alerts: 'Alerts', all: 'Alle aktualisieren' };
    btn.disabled = false; btn.textContent = labels[service] || service;
  }
}
</script>
