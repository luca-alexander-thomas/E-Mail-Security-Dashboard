<%- include('../partials/head', { title: 'Updates' }) %>

<div class="flex h-full min-h-screen">
  <%- include('../partials/sidebar') %>

  <main class="flex-1 lg:ml-64 pt-14 lg:pt-0 p-4 lg:p-6 overflow-y-auto min-w-0">

    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-2xl font-bold text-slate-900 dark:text-white">Software Updates</h1>
        <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">Versionsverwaltung &amp; automatische Aktualisierung</p>
      </div>
      <%
        const modeLabels = { disabled: 'Deaktiviert', check: 'Nur prüfen', auto: 'Automatisch' };
        const modeColors = {
          disabled: 'bg-slate-100 text-slate-600 dark:bg-slate-700 dark:text-slate-400',
          check:    'bg-blue-100 text-blue-700 dark:bg-blue-900/40 dark:text-blue-300',
          auto:     'bg-green-100 text-green-700 dark:bg-green-900/40 dark:text-green-300',
        };
      %>
      <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-semibold <%= modeColors[mode] || modeColors.disabled %>">
        <span class="w-1.5 h-1.5 rounded-full <%= mode === 'auto' ? 'bg-green-500 animate-pulse' : mode === 'check' ? 'bg-blue-500' : 'bg-slate-400' %>"></span>
        Modus: <%= modeLabels[mode] || mode %>
      </span>
    </div>

    <!-- Version Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
      <!-- Aktuelle Version -->
      <div class="bg-white dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700 p-5 shadow-sm">
        <p class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-3">Installierte Version</p>
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-lg bg-blue-100 dark:bg-blue-900/40 flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
          </div>
          <div>
            <p class="text-2xl font-bold text-slate-900 dark:text-white font-mono"><%= current.version %></p>
            <% if (current.buildDate) { %>
              <p class="text-xs text-slate-400 mt-0.5">Build: <%= new Date(current.buildDate).toLocaleDateString('de-DE', {day:'2-digit',month:'2-digit',year:'numeric'}) %></p>
            <% } else { %>
              <p class="text-xs text-slate-400 mt-0.5">Entwicklungsversion</p>
            <% } %>
          </div>
        </div>
      </div>

      <!-- Neueste Version -->
      <div id="latest-card" class="bg-white dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700 p-5 shadow-sm">
        <p class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider mb-3">Neueste Version</p>
        <% if (lastCheck) { %>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-lg flex items-center justify-center flex-shrink-0
              <%= lastCheck.hasUpdate ? 'bg-amber-100 dark:bg-amber-900/40' : 'bg-green-100 dark:bg-green-900/40' %>">
              <% if (lastCheck.hasUpdate) { %>
                <svg class="w-5 h-5 text-amber-600 dark:text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                </svg>
              <% } else { %>
                <svg class="w-5 h-5 text-green-600 dark:text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
              <% } %>
            </div>
            <div>
              <p class="text-2xl font-bold font-mono <%= lastCheck.hasUpdate ? 'text-amber-600 dark:text-amber-400' : 'text-green-600 dark:text-green-400' %>">
                <%= lastCheck.latest %>
              </p>
              <% if (lastCheck.publishedAt) { %>
                <p class="text-xs text-slate-400 mt-0.5">
                  Veröffentlicht: <%= new Date(lastCheck.publishedAt).toLocaleDateString('de-DE', {day:'2-digit',month:'2-digit',year:'numeric'}) %>
                </p>
              <% } %>
            </div>
          </div>
        <% } else { %>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-lg bg-slate-100 dark:bg-slate-700 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <p class="text-sm text-slate-400">Noch nicht geprüft.</p>
          </div>
        <% } %>
      </div>
    </div>

    <!-- Status Banner -->
    <% if (!repo) { %>
    <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-xl p-4 mb-6 flex items-start gap-3">
      <svg class="w-5 h-5 text-red-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
      </svg>
      <div>
        <p class="text-sm font-semibold text-red-700 dark:text-red-400">GITHUB_REPO nicht konfiguriert</p>
        <p class="text-xs text-red-600 dark:text-red-500 mt-0.5">Bitte <code class="bg-red-100 dark:bg-red-900/40 px-1 rounded">GITHUB_REPO=benutzername/reponame</code> in der <code class="bg-red-100 dark:bg-red-900/40 px-1 rounded">.env</code> setzen.</p>
      </div>
    </div>
    <% } else if (lastCheck && lastCheck.hasUpdate) { %>
    <div id="update-banner" class="bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-xl p-4 mb-6 flex items-start gap-3">
      <svg class="w-5 h-5 text-amber-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
      </svg>
      <div class="flex-1">
        <p class="text-sm font-semibold text-amber-700 dark:text-amber-400">
          Update verfügbar: <span class="font-mono"><%= lastCheck.current %> → <%= lastCheck.latest %></span>
        </p>
        <% if (lastCheck.releaseUrl) { %>
          <a href="<%= lastCheck.releaseUrl %>" target="_blank" rel="noopener" class="text-xs text-amber-600 dark:text-amber-500 hover:underline">Release-Notes auf GitHub ansehen →</a>
        <% } %>
      </div>
    </div>
    <% } else if (lastCheck && !lastCheck.hasUpdate) { %>
    <div class="bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-xl p-4 mb-6 flex items-center gap-3">
      <svg class="w-5 h-5 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <p class="text-sm font-medium text-green-700 dark:text-green-400">Aktuell — du verwendest die neueste Version.</p>
    </div>
    <% } %>

    <!-- Action Buttons -->
    <div class="bg-white dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700 p-5 mb-6">
      <h2 class="text-sm font-semibold text-slate-700 dark:text-slate-300 mb-4">Aktionen</h2>
      <div class="flex flex-wrap gap-3 items-center">
        <button id="btn-check" onclick="checkUpdate()"
                class="flex items-center gap-2 px-4 py-2.5 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-lg transition-colors disabled:opacity-60 disabled:cursor-not-allowed">
          <svg id="check-icon" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
          Jetzt suchen
        </button>

        <% const canInstall = lastCheck && lastCheck.hasUpdate && lastCheck.downloadUrl; %>
        <button id="btn-install" onclick="installUpdate()"
                <%= !canInstall ? 'disabled' : '' %>
                class="flex items-center gap-2 px-4 py-2.5 text-sm font-medium rounded-lg transition-colors disabled:opacity-40 disabled:cursor-not-allowed
                       <%= canInstall ? 'bg-amber-500 hover:bg-amber-600 text-white' : 'bg-slate-100 dark:bg-slate-700 text-slate-400 dark:text-slate-500' %>">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
          </svg>
          Update installieren
        </button>

        <% if (lastCheck) { %>
          <span class="text-xs text-slate-400">
            Zuletzt geprüft: <%= new Date(lastCheck.checked).toLocaleString('de-DE') %>
          </span>
        <% } %>
      </div>

      <!-- Status Meldung -->
      <div id="action-status" class="hidden mt-4 p-3 rounded-lg text-sm"></div>

      <!-- Neustart-Hinweis (nach Install) -->
      <div id="restart-notice" class="hidden mt-4 p-4 bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg">
        <div class="flex items-center gap-3">
          <svg class="w-5 h-5 text-blue-500 animate-spin flex-shrink-0" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
          </svg>
          <div>
            <p class="text-sm font-semibold text-blue-700 dark:text-blue-400">Update wird installiert …</p>
            <p class="text-xs text-blue-600 dark:text-blue-500 mt-0.5">Der Server startet gleich neu. Die Seite lädt sich automatisch neu.</p>
          </div>
        </div>
        <div class="mt-3 h-1.5 bg-blue-100 dark:bg-blue-900 rounded-full overflow-hidden">
          <div id="restart-progress" class="h-full bg-blue-500 rounded-full transition-all duration-1000" style="width:0%"></div>
        </div>
      </div>
    </div>

    <!-- Release Notes -->
    <% if (lastCheck && lastCheck.hasUpdate && lastCheck.releaseNotes) { %>
    <details class="bg-white dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700 mb-6 overflow-hidden">
      <summary class="px-5 py-4 text-sm font-semibold text-slate-700 dark:text-slate-200 cursor-pointer hover:bg-slate-50 dark:hover:bg-slate-700/50 select-none flex items-center justify-between">
        <span>Release Notes: <%= lastCheck.latest %></span>
        <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
        </svg>
      </summary>
      <div class="px-5 pb-5 pt-1">
        <pre class="text-xs text-slate-600 dark:text-slate-300 whitespace-pre-wrap font-mono bg-slate-50 dark:bg-slate-900/50 rounded-lg p-4 overflow-x-auto"><%= lastCheck.releaseNotes %></pre>
      </div>
    </details>
    <% } %>

    <!-- Update-Protokoll -->
    <div class="bg-white dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700 overflow-hidden">
      <div class="px-5 py-4 border-b border-slate-100 dark:border-slate-700 flex items-center justify-between">
        <h2 class="text-sm font-semibold text-slate-700 dark:text-slate-200">Update-Protokoll</h2>
        <span class="text-xs text-slate-400"><%= log.length %> Einträge</span>
      </div>

      <% if (log.length === 0) { %>
      <div class="px-5 py-10 text-center">
        <svg class="w-10 h-10 mx-auto mb-2 text-slate-300 dark:text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
        </svg>
        <p class="text-sm text-slate-400">Noch keine Einträge vorhanden.</p>
        <p class="text-xs text-slate-400 mt-1">Suche nach Updates um den ersten Eintrag zu erzeugen.</p>
      </div>
      <% } else { %>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-slate-50 dark:bg-slate-700/50 border-b border-slate-200 dark:border-slate-700">
              <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase">Zeitpunkt</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase">Typ</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase">Von</th>
              <th class="px-4 py-3 text-left text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase">Zu / Status</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100 dark:divide-slate-700">
            <% log.forEach(entry => {
              const typeLabels = {
                check:            { label: 'Prüfung',           badge: 'bg-blue-100 text-blue-700 dark:bg-blue-900/40 dark:text-blue-300' },
                install_start:    { label: 'Install Start',     badge: 'bg-amber-100 text-amber-700 dark:bg-amber-900/40 dark:text-amber-300' },
                install_complete: { label: 'Install Fertig',    badge: entry.success ? 'bg-green-100 text-green-700 dark:bg-green-900/40 dark:text-green-300' : 'bg-red-100 text-red-700 dark:bg-red-900/40 dark:text-red-300' },
                install_error:    { label: 'Install Fehler',    badge: 'bg-red-100 text-red-700 dark:bg-red-900/40 dark:text-red-300' },
              };
              const tc = typeLabels[entry.type] || { label: entry.type, badge: 'bg-slate-100 text-slate-600 dark:bg-slate-700 dark:text-slate-400' };
            %>
            <tr class="hover:bg-slate-50 dark:hover:bg-slate-700/30">
              <td class="px-4 py-3 text-xs text-slate-500 dark:text-slate-400 whitespace-nowrap">
                <%= new Date(entry.timestamp).toLocaleString('de-DE') %>
              </td>
              <td class="px-4 py-3">
                <span class="inline-flex px-2 py-0.5 rounded text-xs font-semibold <%= tc.badge %>">
                  <%= tc.label %>
                </span>
              </td>
              <td class="px-4 py-3 text-xs font-mono text-slate-600 dark:text-slate-300">
                <%= entry.current || entry.from || '–' %>
              </td>
              <td class="px-4 py-3 text-xs">
                <% if (entry.type === 'check') { %>
                  <span class="<%= entry.result === 'update_available' ? 'text-amber-600 dark:text-amber-400 font-semibold' : 'text-green-600 dark:text-green-400' %>">
                    <%= entry.result === 'update_available' ? `Update: ${entry.latest}` : 'Aktuell' %>
                  </span>
                <% } else if (entry.type === 'install_start') { %>
                  <span class="font-mono text-slate-600 dark:text-slate-300"><%= entry.to || '–' %></span>
                <% } else if (entry.type === 'install_complete') { %>
                  <% if (entry.success) { %>
                    <span class="text-green-600 dark:text-green-400 font-semibold">✓ Erfolgreich (<%= entry.version %>)</span>
                  <% } else { %>
                    <span class="text-red-600 dark:text-red-400" title="<%= entry.error || '' %>">✗ Fehlgeschlagen</span>
                  <% } %>
                <% } else if (entry.type === 'install_error') { %>
                  <span class="text-red-600 dark:text-red-400 truncate max-w-xs block" title="<%= entry.error %>"><%= entry.error %></span>
                <% } else { %>
                  <span class="text-slate-400">–</span>
                <% } %>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>

  </main>
</div>

<script>
async function checkUpdate() {
  const btn = document.getElementById('btn-check');
  const status = document.getElementById('action-status');
  btn.disabled = true;
  btn.innerHTML = `<svg class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/></svg> Suche …`;

  try {
    const r = await fetch('/dashboard/updates/check', { method: 'POST' });
    const data = await r.json();
    if (data.ok) {
      // Seite neu laden um aktuellen Status zu zeigen
      location.reload();
    } else {
      showStatus('error', data.error || 'Unbekannter Fehler');
    }
  } catch (e) {
    showStatus('error', 'Netzwerkfehler: ' + e.message);
  }
  btn.disabled = false;
  btn.innerHTML = `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg> Jetzt suchen`;
}

async function installUpdate() {
  if (!confirm('Update jetzt installieren? Der Server wird danach kurz neu gestartet.')) return;

  const btn = document.getElementById('btn-install');
  const notice = document.getElementById('restart-notice');
  const progress = document.getElementById('restart-progress');
  btn.disabled = true;

  try {
    const r = await fetch('/dashboard/updates/install', { method: 'POST' });
    const data = await r.json();
    if (data.ok) {
      notice.classList.remove('hidden');
      // Progressbar über 35 Sekunden füllen
      let pct = 0;
      const iv = setInterval(() => {
        pct = Math.min(95, pct + (pct < 50 ? 3 : 1));
        progress.style.width = pct + '%';
      }, 1000);
      // Nach 35s Seite neu laden (Server sollte wieder da sein)
      setTimeout(() => {
        clearInterval(iv);
        progress.style.width = '100%';
        setTimeout(() => location.reload(), 800);
      }, 35000);
    } else {
      showStatus('error', data.error || 'Installation fehlgeschlagen');
      btn.disabled = false;
    }
  } catch (e) {
    showStatus('error', 'Netzwerkfehler: ' + e.message);
    btn.disabled = false;
  }
}

function showStatus(type, msg) {
  const el = document.getElementById('action-status');
  el.className = `mt-4 p-3 rounded-lg text-sm ${type === 'error' ? 'bg-red-50 dark:bg-red-900/20 text-red-700 dark:text-red-400 border border-red-200 dark:border-red-800' : 'bg-green-50 dark:bg-green-900/20 text-green-700 dark:text-green-400 border border-green-200 dark:border-green-800'}`;
  el.textContent = msg;
  el.classList.remove('hidden');
  setTimeout(() => el.classList.add('hidden'), 6000);
}
</script>

</body>
</html>
