# Server
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000
SESSION_SECRET=change-this-to-a-very-long-random-string-min-32-chars

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=dmarc_user
DB_PASSWORD=your_db_password
DB_NAME=dmarc_db
DB_TABLE=dmarc_reports

# Microsoft Entra ID (Azure AD)
# Wird für OIDC-Login UND Graph API Client Credentials verwendet.
# Benötigte App-Permissions (Application, nicht Delegated):
#   SecurityEvents.Read.All, Reports.Read.All, SecurityAlert.Read.All
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=your-client-secret-value
AZURE_REDIRECT_URI=http://localhost:3000/auth/callback

# DNS Health Check
# Kommagetrennte Liste der zu prüfenden Domains
DNS_CHECK_DOMAINS=example.com
# DKIM-Selector (Standard: selector1 für Microsoft 365)
DNS_CHECK_DKIM_SELECTOR=selector1

# Dev-Tools: Daten-Abruf-Buttons in der Sidebar anzeigen
# Auf true setzen um manuelle Refresh-Buttons anzuzeigen (unabhängig von NODE_ENV)
SHOW_DEV_TOOLS=false

# ─── Auto-Update ───────────────────────────────────────────────────────────────
# GitHub-Repository (öffentlich oder privat mit GITHUB_TOKEN)
GITHUB_REPO=dein-benutzername/DMARC-Analyzer-Dashboard

# Optional: GitHub Personal Access Token (nur bei privatem Repo oder um Rate-Limits zu umgehen)
# GITHUB_TOKEN=ghp_...

# Update-Modus:
#   disabled  – kein automatischer Check (Standard)
#   check     – prüft automatisch, installiert aber NICHT ohne Bestätigung
#   auto      – prüft UND installiert automatisch
UPDATE_MODE=check

# Intervall zwischen automatischen Checks (in Stunden, Standard: 24)
UPDATE_CHECK_INTERVAL=24

# Restart-Methode nach einem Update:
#   docker  – sendet SIGTERM an den Node-Prozess, Docker startet den Container neu (Standard für Container)
#   pm2     – ruft "pm2 restart <PM2_APP_NAME>" auf (für direkte PM2-Setups)
#   signal  – wie docker, liest PID aus .node-pid Datei
RESTART_METHOD=docker

# PM2-App-Name (nur nötig wenn RESTART_METHOD=pm2)
# Abrufbar mit: pm2 list
PM2_APP_NAME=
